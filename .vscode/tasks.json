{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI: Check docs language",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "python3 \"${workspaceFolder}/tools/ai/check_docs_language.py\" $(python3 \"${workspaceFolder}/tools/ai/list_policy_ai_docs.py\")"
      ],
      "problemMatcher": []
    },
    {
      "label": "AI: Check docs references",
      "type": "shell",
      "command": "grep",
      "args": [
        "-RInE",
        "tools/ai/check_docs_language.py|tools/ai/list_policy_ai_docs.py|AI: Check docs language|## Scope",
        "${workspaceFolder}/AGENTS.md",
        "${workspaceFolder}/docs/AI_DEVELOPMENT_PLAYBOOK.md",
        "${workspaceFolder}/docs/AI_DOCS_LANGUAGE_POLICY.md",
        "${workspaceFolder}/.vscode/tasks.json"
      ],
      "problemMatcher": []
    },
    {
      "label": "AI: Post-edit checks",
      "dependsOrder": "sequence",
      "dependsOn": [
        "AI: Check docs language",
        "AI: Check docs references"
      ],
      "problemMatcher": []
    }
  ]
}
